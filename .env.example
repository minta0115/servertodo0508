# Railway 环境变量配置示例
# 在Railway Dashboard中设置这些变量

# 数据库配置（Railway自动提供PostgreSQL）
DATABASE_URL=postgresql://...

# 后端配置
PORT=3000
NODE_ENV=production
JWT_SECRET=your-secret-key-change-this

# API密钥配置
DEFAULT_NVIDIA_API_KEY=nvapi-test-key
DEFAULT_MINIMAX_API_KEY=mm-test-key

# 前端API地址（不需要设置，自动识别）
VITE_API_BASE=/api
=======
# Server configuration
PORT=3001
NODE_ENV=production

# JWT Secret - change this in production!
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# PostgreSQL Database URL (get from Railway/Render/Supabase)
DATABASE_URL=postgresql://user:password@host:5432/todos

# OpenAI/NVIDIA API
OPENAI_API_KEY=your-nvidia-api-key

# Note: NVIDIA API uses baseURL https://integrate.api.nvidia.com/v1
